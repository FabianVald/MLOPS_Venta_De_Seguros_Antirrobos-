# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Datos crudos: dataset pequeño y estático (~1.7MB), se versiona directamente
# en Git para que `git clone` + `dvc repro` funcione sin configurar un remote
# de DVC (S3/GCS/Azure). Los datos PROCESADOS sí se excluyen: son
# reproducibles ejecutando el pipeline (dvc.yaml), no deben vivir en Git.
data/processed/*.csv
!data/processed/.gitkeep

# Modelos y artefactos generados
models/*.pkl
models/*.json
reports/figures/**
!reports/figures/.gitkeep
logs/*.log

# MLflow
mlruns/
mlartifacts/

# DVC
/.dvc/cache
/.dvc/tmp

# IDE / OS
.vscode/
.idea/
.claude/settings.local.json
.DS_Store
Thumbs.db
